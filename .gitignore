.wrangler/
**/.wrangler/
.dev.vars
**/.dev.vars
.mf/

# Env & secrets — NEVER commit the Anthropic key
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
