{
  "name": "@sehari/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply sehari-db --local",
    "migrate:remote": "wrangler d1 migrations apply sehari-db --remote",
    "seed:local": "wrangler d1 execute sehari-db --local --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "ts-fsrs": "^4.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
